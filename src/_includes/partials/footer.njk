<footer class="site-footer" role="contentinfo" data-pagefind-ignore>
  <div class="container">

    {# ── Subscribe strip ── #}
    <div class="footer-subscribe-strip">

      <div>
        <p style="font-family: var(--font-masthead); font-size: var(--text-xl); color: var(--color-ink); margin-bottom: var(--space-2); display: flex; align-items: center; gap: 0.5rem;">
          <img src="/assets/favicon.svg" alt="" aria-hidden="true" width="24" height="24">{{ site.title }}
        </p>
        <p style="font-size: var(--text-sm); color: var(--color-ink-muted); max-width: 42ch; line-height: var(--leading-normal); margin-bottom: var(--space-4);">
          {{ site.description }}
        </p>
        <p style="font-size: var(--text-xs); color: var(--color-ink-faint);">
          Created in {{ site.founded }} by Isabelle.
        </p>
      </div>

      <div>
        {% set subscribeVariant = "footer" %}
        {% include "partials/subscribe.njk" %}
      </div>

    </div>

    {# ── Footer grid — 4 columns ── #}
    <div class="site-footer__grid">

      {# Sections #}
      <div>
        <p style="font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-faint); margin-bottom: var(--space-3);">Sections</p>
        <ul class="site-footer__nav">
          {% for item in site.nav %}
          <li><a href="{{ item.url }}">{{ item.label }}</a></li>
          {% endfor %}
        </ul>
      </div>

      {# About & Community #}
      <div>
        <p style="font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-faint); margin-bottom: var(--space-3);">About</p>
        <ul class="site-footer__nav">
          <li><a href="/about/">About</a></li>
          <li><a href="/masthead/">Masthead</a></li>
          <li><a href="/contributors/">Contributors</a></li>
          <li><a href="/features/">Features</a></li>
          <li><a href="/style-guide/">Style Guide</a></li>
          <li><a href="/support/">Support Us</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>

      {# Browse & Discover #}
      <div>
        <p style="font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-faint); margin-bottom: var(--space-3);">Discover</p>
        <ul class="site-footer__nav">
          <li><a href="/editions/">Editions</a></li>
          <li><a href="/archives/">Archives</a></li>
          <li><a href="/topics/">Topics</a></li>
          <li><a href="/corrections/">Corrections</a></li>
          <li><a href="/reading-list/">Reading List</a></li>
          <li><a href="/random/">Surprise Me</a></li>
        </ul>
      </div>

      {# Connect #}
      <div>
        <p style="font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-faint); margin-bottom: var(--space-3);">Connect</p>
        <ul class="site-footer__nav">
          <li><a href="/newsletter/">Newsletter</a></li>
          <li><a href="/submit/">Submit a Piece</a></li>
          <li><a href="/feed.xml">RSS Feed</a></li>
          <li><a href="/sitemap.xml">Sitemap</a></li>
          <li><a href="/privacy/">Privacy</a></li>
        </ul>
      </div>

    </div>

    {# ── Bottom bar ── #}
    <div class="site-footer__bottom">
      <p style="font-size: var(--text-xs); color: var(--color-ink-faint);">
        &copy; {{ currentYear }} {{ site.title }}. All rights reserved.
      </p>
      <p style="font-size: var(--text-xs); color: var(--color-ink-faint);">
        Website by <a href="https://www.pikespeakwebdesigns.com" target="_blank" rel="noopener noreferrer" style="color: var(--color-ink-faint); text-decoration: underline;">Pikes Peak Web Designs</a>
      </p>
    </div>

  </div>{# /.container #}
</footer>
