---
layout: layouts/base.njk
---

<div class="container" style="padding-top: var(--space-12); padding-bottom: var(--space-16);">

  <header style="margin-bottom: var(--space-10); padding-bottom: var(--space-6); border-bottom: 3px solid var(--color-ink);">
    <p style="font-family: var(--font-ui); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-faint); margin-bottom: var(--space-3);">
      {{ role or "Contributor" }}
    </p>
    <h1 style="font-family: var(--font-masthead); font-size: var(--text-3xl); margin-bottom: var(--space-4);">{{ title }}</h1>
    {% if bio %}
    <p style="font-size: var(--text-md); color: var(--color-ink-muted); max-width: 60ch; font-style: italic; line-height: var(--leading-normal);">
      {{ bio }}
    </p>
    {% endif %}
    <a href="/feeds/{{ authorSlug }}.xml"
       style="display: inline-flex; align-items: center; gap: var(--space-2); margin-top: var(--space-4); font-family: var(--font-ui); font-size: var(--text-xs); color: var(--color-ink-faint); text-decoration: none; text-transform: uppercase; letter-spacing: 0.06em;">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <circle cx="5" cy="19" r="2"/>
        <path d="M4 4a16 16 0 0 1 16 16h-3A13 13 0 0 0 4 7V4z"/>
        <path d="M4 11a9 9 0 0 1 9 9H10a6 6 0 0 0-6-6v-3z"/>
      </svg>
      RSS Feed for {{ title }}
    </a>
  </header>

  <div class="section-grid">
    <div class="section-grid__main">

      <p style="font-family: var(--font-ui); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-faint); border-bottom: 1px solid var(--color-rule); padding-bottom: var(--space-3); margin-bottom: var(--space-6);">
        Articles by {{ title }}
      </p>

      {% set authorArticles = collections.allContent | where("author", authorSlug) %}
      {% if authorArticles.length == 0 %}
      <p style="color: var(--color-ink-muted); font-style: italic;">No articles published yet.</p>
      {% else %}
      <ul class="article-list" role="list">
        {% for item in authorArticles %}
        <li class="article-list__item">
          {% set article = item %}
          {% set size = "sm" %}
          {% include "partials/article-card.njk" %}
        </li>
        {% endfor %}
      </ul>
      {% endif %}

    </div>

    <aside class="section-grid__sidebar">
      <div class="sidebar-widget">
        <p class="sidebar-widget__title">All Contributors</p>
        <ul style="list-style: none; padding: 0;">
          {% for slug, authorData in authors %}
          <li style="padding: var(--space-2) 0; border-bottom: 1px solid var(--color-rule);">
            <a href="/author/{{ slug }}/" style="font-family: var(--font-ui); font-size: var(--text-sm); color: var(--color-ink-muted); text-decoration: none;">
              {{ authorData.name }}
            </a>
          </li>
          {% endfor %}
        </ul>
      </div>
    </aside>

  </div>
</div>
