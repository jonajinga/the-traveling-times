---
layout: base
title: Archives
description: The complete archive of The Traveling Times.
permalink: /archives/
---

<div class="container" style="padding-top: var(--space-12); padding-bottom: var(--space-16);">

  <header style="margin-bottom: var(--space-10); padding-bottom: var(--space-6); border-bottom: 3px solid var(--color-ink);">
    <h1 style="font-family: var(--font-masthead); font-size: clamp(1.8rem, 5vw, 3.815rem); margin-bottom: var(--space-4);">Archives</h1>
    <p style="font-size: var(--text-lg); color: var(--color-ink-muted); font-style: italic;">
      Every piece published in The Traveling Times, in reverse chronological order.
    </p>
  </header>

  {% set dateGroups = collections.allContent | groupByDate %}
  {% for group in dateGroups %}
  <section id="{{ group.date }}" style="margin-bottom: var(--space-10);">

    <h2 style="font-family: var(--font-ui); font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-faint); border-bottom: 1px solid var(--color-rule); padding-bottom: var(--space-3); margin-bottom: var(--space-5);">
      <a href="#{{ group.date }}" style="color: inherit; text-decoration: none;">{{ group.articles[0].date | readableDate }}</a>
    </h2>

    <ul class="article-list" role="list">
      {% for item in group.articles %}
      <li class="article-list__item">
        <div style="display: flex; justify-content: space-between; align-items: baseline; gap: var(--space-6); flex-wrap: wrap;">
          <a href="{{ item.url }}" style="font-family: var(--font-headline); font-size: var(--text-md); font-weight: 600; color: var(--color-ink); text-decoration: none; line-height: var(--leading-snug);">
            {{ item.data.title }}
          </a>
          {% if item.data.section %}
          <a href="/{{ item.data.section | lower | replace(' ', '-') }}/"
             class="section-badge section-badge--{{ item.data.section | lower | replace(' ', '-') }}"
             style="flex-shrink: 0; font-size: var(--text-xs);">
            {{ item.data.section }}
          </a>
          {% endif %}
        </div>
        {% if item.data.description %}
        <p style="color: var(--color-ink-muted); font-size: var(--text-sm); margin-top: var(--space-1); margin-bottom: 0;">
          {{ item.data.description }}
        </p>
        {% endif %}
      </li>
      {% endfor %}
    </ul>

  </section>
  {% endfor %}

</div>
